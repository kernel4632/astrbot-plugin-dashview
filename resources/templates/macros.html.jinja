{% macro header(d) %}
<div class="hero-card">
  <div class="hero-main">
    <div class="hero-avatar-box">
      <img class="hero-avatar" data-src="/api/bot_avatar/{{ info.self_id }}" alt="Avatar" />
    </div>
    <div class="hero-content">
      <h1 class="hero-title">阿柯AKer</h1>
    </div>
  </div>
  <div class="hero-side">
    <div class="hero-health health-{{ d.overview.health_level }}">{{ d.overview.health_text }}</div>
  </div>
</div>
{% endmacro %}

{% macro overview(d) %}
<div class="panel-card overview-panel">
  <div class="section-head">
    <div>
      <div class="section-kicker">Resource Overview</div>
      <h3 class="section-title">资源使用率</h3>
    </div>
  </div>
  <div class="meter-list">
    {% for item in d.resource_cards %}
    <div class="meter-card meter-{{ item.color }}">
      <div class="meter-head">
        <div class="meter-dot meter-dot-{{ item.color }}"></div>
        <div class="meter-name">{{ item.name }}</div>
      </div>
      <div class="meter-value">{{ item.value }}</div>
      <div class="meter-detail">{{ item.detail }}</div>
      <div class="meter-wave meter-wave-{{ item.wave }} meter-wave-{{ loop.index }}"></div>
    </div>
    {% endfor %}
  </div>
</div>
{% endmacro %}

{% macro services_monitor(d) %}
<div class="monitor-group">
  <div class="panel-card services-panel">
    <div class="section-head compact">
      <div>
        <div class="section-kicker">Service Monitor</div>
        <h3 class="section-title">服务状态</h3>
      </div>
    </div>
    <div class="service-list">
      {% for service in d.services_status %}
      <div class="service-card service-{{ service.status }}">
        <div class="service-row">
          <div class="service-main">
            <div class="service-name">{{ service.name }}</div>
            <div class="service-target">{{ service.url }}</div>
          </div>
          <div class="service-meta">
            <div class="service-latency">{{ service.ping_text }}</div>
            <span class="service-badge badge-{{ service.status_color }}">{{ service.status_text }}</span>
          </div>
        </div>
        <div class="service-foot">
          <div class="service-message">{{ service.message }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="panel-card details-panel">
    <div class="section-head compact">
      <div>
        <div class="section-kicker">System Detail</div>
        <h3 class="section-title">系统信息</h3>
      </div>
    </div>
    <div class="info-grid">
      {% for item in d.system_details.cards %}
      <div class="info-item">
        <div class="info-label">{{ item.label }}</div>
        <div class="info-value">{{ item.value }}</div>
      </div>
      {% endfor %}
      <div class="info-item info-summary">
        <div class="info-summary-text">{{ d.system_details.status_text }}</div>
      </div>
    </div>
  </div>
</div>
{% endmacro %}
