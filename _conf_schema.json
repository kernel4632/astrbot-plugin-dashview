{
  "nickname": {
    "description": "头像旁边显示的名称",
    "type": "string",
    "hint": "会显示在监控面板左上角头像旁边",
    "default": "阿柯AKer"
  },
  "services": {
    "description": "监控服务列表",
    "type": "list",
    "hint": "配置需要监控的服务，支持 HTTP 和 TCP 类型",
    "default": [
      {
        "name": "超级主核API",
        "type": "http",
        "url": "https://api.hujiarong.site/"
      },
      {
        "name": "主核Kernyr网站",
        "type": "http",
        "url": "https://www.hujiarong.site/"
      }
    ],
    "items": {
      "name": {
        "description": "服务名称",
        "type": "string",
        "hint": "显示在监控面板上的服务名称"
      },
      "type": {
        "description": "服务类型",
        "type": "string",
        "options": [
          "http",
          "tcp"
        ],
        "hint": "HTTP 或 TCP 服务"
      },
      "url": {
        "description": "HTTP 服务地址",
        "type": "string",
        "hint": "仅 HTTP 类型需要填写"
      },
      "host": {
        "description": "TCP 服务主机",
        "type": "string",
        "hint": "仅 TCP 类型需要填写"
      },
      "port": {
        "description": "TCP 服务端口",
        "type": "int",
        "hint": "仅 TCP 类型需要填写"
      }
    }
  },
  "success_text": {
    "description": "全部服务正常时显示的文字",
    "type": "string",
    "hint": "显示在监控面板右下角的状态结论区",
    "default": "阿柯牛逼"
  },
  "fail_text": {
    "description": "有服务异常时显示的文字",
    "type": "string",
    "hint": "显示在监控面板右下角的状态结论区",
    "default": "阿柯死了"
  },
  "timeout": {
    "description": "服务检测超时时间",
    "type": "int",
    "hint": "单位：秒",
    "default": 5,
    "slider": {
      "min": 1,
      "max": 30,
      "step": 1
    }
  },
  "model_probe_interval_hours": {
    "description": "模型定时探测间隔",
    "type": "float",
    "hint": "单位：小时。0 表示关闭后台定时探测；例如 1 表示每小时探测一次，只记录历史，不主动推送图片。",
    "default": 0,
    "slider": {
      "min": 0,
      "max": 72,
      "step": 0.5
    }
  },
  "model_probe_run_on_start": {
    "description": "启动后立即探测一次模型",
    "type": "bool",
    "hint": "开启后插件启动时会立刻探测一次模型并写入历史，不会主动推送图片。",
    "default": false
  },
  "model_history_size": {
    "description": "模型历史状态格子数量",
    "type": "int",
    "hint": "仪表盘里每个模型显示最近多少次探测状态，默认 12 次。",
    "default": 12,
    "slider": {
      "min": 6,
      "max": 48,
      "step": 1
    }
  },
  "model_stats_window_hours": {
    "description": "模型统计窗口小时数",
    "type": "int",
    "hint": "用于计算平均延迟、可用性和成功次数的时间范围，默认 24 小时。",
    "default": 24,
    "slider": {
      "min": 1,
      "max": 168,
      "step": 1
    }
  },
  "model_timeout": {
    "description": "模型探测超时秒数",
    "type": "int",
    "hint": "单个模型等待回复的最长时间，默认 30 秒",
    "default": 30,
    "slider": {
      "min": 5,
      "max": 120,
      "step": 1
    }
  },
  "model_concurrency": {
    "description": "模型检测并发数",
    "type": "int",
    "hint": "同时探测几个模型，默认 10",
    "default": 10,
    "slider": {
      "min": 1,
      "max": 50,
      "step": 1
    }
  },
  "model_slow_ms": {
    "description": "模型较慢判定阈值",
    "type": "int",
    "hint": "延迟超过这个毫秒数就算较慢，默认 8000",
    "default": 8000,
    "slider": {
      "min": 500,
      "max": 30000,
      "step": 1000
    }
  },
  "model_max_models": {
    "description": "每个 Provider 最多检测几个模型",
    "type": "int",
    "hint": "限值可加快检测速度，0 表示不限制",
    "default": 0,
    "slider": {
      "min": 0,
      "max": 100,
      "step": 1
    }
  }
}
